---
import '@fontsource-variable/inter';

// 'DM Sans'
// Nunito
// Dosis
// Outfit
// Roboto
// Literata
// 'IBM Plex Sans'
// Karla
// Poppins
// 'Fira Sans'
// 'Libre Franklin'
// Inconsolata
// Raleway
// Oswald
// 'Space Grotesk'
// Urbanist
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(0 120 212);
    --aw-color-secondary: rgb(0 32 80);
    --aw-color-accent: rgb(0 183 195);

    --aw-color-text-heading: rgb(0 0 0);
    --aw-color-text-default: rgb(30 41 59);
    --aw-color-text-muted: rgb(30 41 59 / 66%);
    --aw-color-bg-page: rgb(248 250 252);

    --aw-color-bg-page-dark: rgb(15 23 42);

    ::selection {
      background-color: rgb(0 120 212 / 20%);
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(56 152 236);
    --aw-color-secondary: rgb(0 183 195);
    --aw-color-accent: rgb(212 135 15);

    --aw-color-text-heading: rgb(247, 248, 248);
    --aw-color-text-default: rgb(229 236 246);
    --aw-color-text-muted: rgb(229 236 246 / 66%);
    --aw-color-bg-page: rgb(15 23 42);

    ::selection {
      background-color: rgb(0 120 212 / 30%);
      color: snow;
    }
  }
</style>
