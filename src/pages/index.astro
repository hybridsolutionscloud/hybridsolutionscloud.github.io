---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import Steps from '~/components/widgets/Steps.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Note from '~/components/widgets/Note.astro';

import hybridHeroImg from '~/assets/images/logo-bridge-primary.svg';

const metadata = {
  title: 'Hybrid Cloud Made Simple | Hybrid Cloud Solutions, LLC',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Schedule a Consult',
        href: '/contact',
        icon: 'tabler:calendar',
      },
      { text: 'Our Services', href: '/services' },
    ]}
    image={{ src: hybridHeroImg, alt: 'Hybrid Cloud Solutions — Hybrid Cloud Architecture' }}
  >
    <Fragment slot="title">
      Hybrid Cloud <span class="text-accent dark:text-white">Made Simple</span>
    </Fragment>

    <Fragment slot="subtitle">
      From Azure Local to Hyper-V and Azure Arc — grounded, resilient hybrid cloud solutions designed for the edge and
      the enterprise.
      <span class="font-semibold">Hybrid Cloud Solutions, LLC</span> helps organizations modernize with confidence using
      Microsoft technologies.
    </Fragment>
  </Hero>

  <!-- Note Widget ******************* -->

  <Note
    title="Microsoft MVP & MCT-Led Consulting:"
    description="Real-world hybrid cloud expertise backed by recognized community leadership and Microsoft Certified Trainer credentials."
  />

  <!-- Features Widget *************** -->

  <Features
    id="services"
    tagline="What We Do"
    title="Hybrid Cloud Services"
    subtitle="We specialize in designing, deploying, and managing Microsoft hybrid cloud infrastructure — bridging your datacenter and the cloud."
    items={[
      {
        title: 'Azure Local (Azure Stack HCI)',
        description:
          'Deploy and manage hyperconverged infrastructure with Azure Local — bringing Azure services to your on-premises environment.',
        icon: 'tabler:server',
      },
      {
        title: 'Azure Arc Enablement',
        description:
          'Extend Azure governance, security, and management to any infrastructure — on-premises, edge, or multi-cloud.',
        icon: 'tabler:globe',
      },
      {
        title: 'Hyper-V Cluster Design',
        description:
          'Design and implement resilient Hyper-V clusters with Storage Spaces Direct for high availability and performance.',
        icon: 'tabler:stack-2',
      },
      {
        title: 'Edge & Remote Site Solutions',
        description:
          'Purpose-built hybrid solutions for remote offices, branch locations, and edge environments where connectivity matters.',
        icon: 'tabler:antenna-bars-5',
      },
      {
        title: 'Hybrid Cloud Architecture',
        description:
          'End-to-end architecture and consulting for organizations blending on-premises infrastructure with Azure cloud services.',
        icon: 'tabler:cloud-computing',
      },
      {
        title: 'Automation & Governance',
        description:
          'Azure Policy, Azure Automation, and infrastructure-as-code to keep your hybrid environment consistent and compliant.',
        icon: 'tabler:settings-automation',
      },
    ]}
  />

  <!-- Content Widget **************** -->

  <Content
    isReversed
    tagline="Why Hybrid?"
    title="Not every workload belongs in the public cloud"
    items={[
      {
        title: 'Microsoft MVP & MCT',
        description:
          'Microsoft MVP in Azure and Microsoft Certified Trainer — insights from 30+ conference sessions and real production deployments.',
      },
      {
        title: 'Craftsmanship Meets Cloud',
        description:
          "We approach cloud architecture with the same care you'd find in a woodshop — patient, precise, and purpose-driven.",
      },
      {
        title: 'Edge-Ready Solutions',
        description:
          'We specialize in remote site deployments, secure automation, and Azure services that run on your terms — anywhere.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1558494949-ef010cbdcc31?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
      alt: 'Server Room Infrastructure',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">What Makes Us Different</h3>
      We help you modernize on your own terms — blending Azure capabilities with resilient on-prem infrastructure.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Steps Widget ****************** -->

  <Steps
    title="How We Work"
    items={[
      {
        title: 'Step 1: <span class="font-medium">Discovery</span>',
        description:
          'We start by understanding your current infrastructure, business requirements, and goals. No cookie-cutter assessments — we dig into what makes your environment unique.',
        icon: 'tabler:search',
      },
      {
        title: 'Step 2: <span class="font-medium">Design</span>',
        description:
          'We architect a solution tailored to your needs — selecting the right mix of Azure Local, Azure Arc, Hyper-V, and cloud services for your workloads.',
        icon: 'tabler:ruler-2',
      },
      {
        title: 'Step 3: <span class="font-medium">Deploy</span>',
        description:
          'Hands-on implementation with careful attention to detail. We build it right the first time — tested, validated, and documented.',
        icon: 'tabler:rocket',
      },
      {
        title: 'Ongoing Support',
        icon: 'tabler:check',
        description:
          "We don't disappear after deployment. We offer continued guidance, training, and support to keep your hybrid cloud running strong.",
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1551434678-e076c223a692?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
      alt: 'Consulting Process',
    }}
  />

  <!-- Testimonials Widget *********** -->

  <Testimonials
    title="What Our Clients Say"
    testimonials={[
      {
        testimonial:
          'Working with Hybrid Cloud Solutions was a game-changer. Their knowledge of Azure Arc and on-prem infrastructure helped us move faster without compromising on governance.',
        name: 'Enterprise Infrastructure Lead',
        job: 'Public Sector Organization',
      },
      {
        testimonial:
          "Hybrid Cloud Solutions' deep expertise in Azure and hybrid identity made our zero-trust migration seamless. They didn't just implement — they educated our team along the way.",
        name: 'Senior Director of IT',
        job: 'Regional Healthcare Network',
      },
      {
        testimonial:
          "We needed someone who understood both the cloud and the legacy systems we couldn't rip out overnight. Hybrid Cloud Solutions bridged that gap perfectly.",
        name: 'VP of Technology',
        job: 'Mid-Market Financial Services Firm',
      },
      {
        testimonial:
          'The certifications speak for themselves, but it\'s the hands-on experience that sets Hybrid Cloud Solutions apart. Our Azure Arc deployment was production-ready in half the time we expected.',
        name: 'Cloud Operations Manager',
        job: 'Manufacturing Company',
      },
      {
        testimonial:
          'From architecture review to implementation, the engagement was thorough and professional. Our hybrid environment is more secure and easier to manage than it\'s ever been.',
        name: 'CISO',
        job: 'State Government Agency',
      },
      {
        testimonial:
          "Hybrid Cloud Solutions designed and deployed a six-node Hyper-V cluster at our main office, then stood up two additional clusters across our western data centers with Hyper-V Replica for disaster recovery. Everything was built to Microsoft's Cloud Adoption Framework and Well-Architected Framework standards. Our members' data has never been more resilient.",
        name: 'IT Director',
        job: 'Community Credit Union',
      },
      {
        testimonial:
          'We brought Hybrid Cloud Solutions in for an Azure Local proof of concept, and they exceeded every expectation. The deployment validated our hybrid strategy and gave leadership the confidence to move forward. They understood our manufacturing environment and delivered results fast.',
        name: 'Director of Infrastructure',
        job: 'National Building Supply & Cabinetry Company',
      },
    ]}
  />

  <!-- Stats Widget ****************** -->

  <Stats
    stats={[
      { title: 'Microsoft Technologies', amount: '10+' },
      { title: 'Years of Experience', amount: '15+' },
      { title: 'Azure & Hybrid Focus', amount: '100%' },
      { title: 'MVP Recognition', amount: '✓' },
    ]}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Get Started',
        href: '/contact',
        icon: 'tabler:arrow-right',
      },
    ]}
  >
    <Fragment slot="title"> Ready to Build Your Hybrid Cloud? </Fragment>

    <Fragment slot="subtitle">
      Let's design a solution that blends the best of Azure with the infrastructure you trust.
    </Fragment>
  </CallToAction>
</Layout>
