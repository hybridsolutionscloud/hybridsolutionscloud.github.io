---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Thank You',
};
---

<Layout metadata={metadata}>
  <HeroText
    tagline="Message Received"
    title="Thank You!"
    subtitle="We've received your message and will get back to you within one business day."
  />

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Back to Home',
        href: '/',
        icon: 'tabler:arrow-left',
      },
      {
        variant: 'secondary',
        text: 'Explore Services',
        href: '/services',
      },
    ]}
  >
    <Fragment slot="title"> While You Wait </Fragment>

    <Fragment slot="subtitle">
      Feel free to explore our services or check out some of our community resources.
    </Fragment>
  </CallToAction>
</Layout>
