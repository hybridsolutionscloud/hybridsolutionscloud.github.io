---
import Layout from '~/layouts/PageLayout.astro';
import { Image } from 'astro:assets';

import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import Features from '~/components/widgets/Features.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

import logoPrimary from '~/assets/images/logo-primary-800.png';
import logoNavy from '~/assets/images/logo-navy-800.png';
import logoBlack from '~/assets/images/logo-black-800.png';
import logoWhite from '~/assets/images/logo-white-800.png';
import horizontalBlue from '~/assets/images/horizontal-blue-1240.png';
import horizontalDark from '~/assets/images/horizontal-dark-1240.png';
import horizontalLight from '~/assets/images/horizontal-light-1240.png';
import markPrimary from '~/assets/images/mark-primary-400.png';
import markNavy from '~/assets/images/mark-navy-400.png';
import markWhite from '~/assets/images/mark-white-400.png';
import ogImage from '~/assets/images/og-image-1200x630.png';

const metadata = {
  title: 'Brand Assets',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero>
    <Fragment slot="title">
      Brand <span class="text-accent dark:text-white">Assets</span>
    </Fragment>

    <Fragment slot="subtitle">
      Everything you need to represent Hybrid Cloud Solutions correctly. Download logos, marks, and brand guidelines for
      use in presentations, events, and partner materials.
    </Fragment>
  </Hero>

  <!-- Brand Guidelines **************** -->

  <Features
    id="guidelines"
    title="Brand Guidelines"
    subtitle="Please follow these guidelines when using our brand assets."
    columns={3}
    items={[
      {
        title: 'Use Our Official Assets',
        description: 'Always use the logos and marks provided on this page. Do not recreate or modify them.',
        icon: 'tabler:check',
      },
      {
        title: 'Maintain Clear Space',
        description: 'Keep adequate spacing around our logo. Do not crowd it with other elements.',
        icon: 'tabler:spacing-horizontal',
      },
      {
        title: 'Respect Color Usage',
        description:
          'Use the correct logo variant for your background. Light logos on dark backgrounds, dark logos on light.',
        icon: 'tabler:palette',
      },
      {
        title: 'Do Not Alter',
        description: 'Do not rotate, stretch, recolor, add effects to, or otherwise modify our logos.',
        icon: 'tabler:ban',
      },
      {
        title: 'Minimum Size',
        description:
          'The logo mark should never appear smaller than 32px. The horizontal logo should be at least 120px wide.',
        icon: 'tabler:ruler-2',
      },
      {
        title: 'Attribution',
        description:
          'When referencing our company, use the full name "Hybrid Cloud Solutions" or "Hybrid Cloud Solutions, LLC."',
        icon: 'tabler:quote',
      },
    ]}
  />

  <!-- Brand Colors **************** -->

  <Content
    id="colors"
    title="Brand Colors"
    subtitle="Our primary color palette."
    isReversed
    image={{
      src: markPrimary,
      alt: 'HCS Brand Mark',
    }}
  >
    <Fragment slot="content">
      <div class="space-y-4">
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 rounded-lg" style="background-color: #0EA5E9;"></div>
          <div>
            <p class="font-semibold">Primary Blue</p>
            <p class="text-sm text-muted">#0EA5E9 · rgb(14, 165, 233)</p>
          </div>
        </div>
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 rounded-lg" style="background-color: #0C4A6E;"></div>
          <div>
            <p class="font-semibold">Navy</p>
            <p class="text-sm text-muted">#0C4A6E · rgb(12, 74, 110)</p>
          </div>
        </div>
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 rounded-lg" style="background-color: #0F172A;"></div>
          <div>
            <p class="font-semibold">Dark Slate</p>
            <p class="text-sm text-muted">#0F172A · rgb(15, 23, 42)</p>
          </div>
        </div>
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 rounded-lg border border-gray-200" style="background-color: #FFFFFF;"></div>
          <div>
            <p class="font-semibold">White</p>
            <p class="text-sm text-muted">#FFFFFF · rgb(255, 255, 255)</p>
          </div>
        </div>
      </div>
    </Fragment>
  </Content>

  <!-- Primary Logos **************** -->

  <div class="max-w-6xl mx-auto px-4 py-16">
    <div class="text-center mb-10">
      <h2 class="text-3xl font-bold">Primary Logos</h2>
      <p class="text-muted mt-2">
        Stacked logo variations for general use. Use the version that provides the best contrast against your
        background.
      </p>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
      <div class="flex flex-col items-center gap-3 p-6 rounded-xl bg-gray-50 dark:bg-slate-800">
        <Image src={logoPrimary} alt="HCS Logo Primary" width={200} class="max-h-48 w-auto object-contain" />
        <span class="text-sm font-medium">Primary (Blue)</span>
      </div>
      <div class="flex flex-col items-center gap-3 p-6 rounded-xl bg-gray-50 dark:bg-slate-800">
        <Image src={logoNavy} alt="HCS Logo Navy" width={200} class="max-h-48 w-auto object-contain" />
        <span class="text-sm font-medium">Navy</span>
      </div>
      <div class="flex flex-col items-center gap-3 p-6 rounded-xl bg-gray-50 dark:bg-slate-800">
        <Image src={logoBlack} alt="HCS Logo Black" width={200} class="max-h-48 w-auto object-contain" />
        <span class="text-sm font-medium">Black</span>
      </div>
      <div class="flex flex-col items-center gap-3 p-6 rounded-xl bg-slate-800 dark:bg-slate-900">
        <Image src={logoWhite} alt="HCS Logo White" width={200} class="max-h-48 w-auto object-contain" />
        <span class="text-sm font-medium text-white">White</span>
      </div>
    </div>
  </div>

  <!-- Horizontal Logos **************** -->

  <div class="max-w-6xl mx-auto px-4 py-16">
    <div class="text-center mb-10">
      <h2 class="text-3xl font-bold">Horizontal Logos</h2>
      <p class="text-muted mt-2">Wide-format logos for headers, banners, email signatures, and partner listings.</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="flex flex-col items-center gap-3 p-6 rounded-xl bg-gray-50 dark:bg-slate-800">
        <Image src={horizontalBlue} alt="HCS Horizontal Blue" width={400} class="max-h-24 w-auto object-contain" />
        <span class="text-sm font-medium">Blue on White</span>
      </div>
      <div class="flex flex-col items-center gap-3 p-6 rounded-xl bg-gray-50 dark:bg-slate-800">
        <Image src={horizontalDark} alt="HCS Horizontal Dark" width={400} class="max-h-24 w-auto object-contain" />
        <span class="text-sm font-medium">Dark</span>
      </div>
      <div class="flex flex-col items-center gap-3 p-6 rounded-xl bg-slate-800 dark:bg-slate-900">
        <Image src={horizontalLight} alt="HCS Horizontal Light" width={400} class="max-h-24 w-auto object-contain" />
        <span class="text-sm font-medium text-white">Light</span>
      </div>
    </div>
  </div>

  <!-- Brand Marks **************** -->

  <div class="max-w-6xl mx-auto px-4 py-16">
    <div class="text-center mb-10">
      <h2 class="text-3xl font-bold">Brand Marks</h2>
      <p class="text-muted mt-2">The standalone bridge icon for favicons, avatars, and small formats.</p>
    </div>
    <div class="grid grid-cols-3 md:grid-cols-3 gap-6 max-w-2xl mx-auto">
      <div class="flex flex-col items-center gap-3 p-6 rounded-xl bg-gray-50 dark:bg-slate-800">
        <Image src={markPrimary} alt="HCS Mark Primary" width={120} class="max-h-32 w-auto object-contain" />
        <span class="text-sm font-medium">Primary</span>
      </div>
      <div class="flex flex-col items-center gap-3 p-6 rounded-xl bg-gray-50 dark:bg-slate-800">
        <Image src={markNavy} alt="HCS Mark Navy" width={120} class="max-h-32 w-auto object-contain" />
        <span class="text-sm font-medium">Navy</span>
      </div>
      <div class="flex flex-col items-center gap-3 p-6 rounded-xl bg-slate-800 dark:bg-slate-900">
        <Image src={markWhite} alt="HCS Mark White" width={120} class="max-h-32 w-auto object-contain" />
        <span class="text-sm font-medium text-white">White</span>
      </div>
    </div>
  </div>

  <!-- Social / OG Image **************** -->

  <Content
    id="social"
    title="Social Media & Open Graph"
    subtitle="Pre-formatted image for social sharing and link previews."
    isReversed
    image={{
      src: ogImage,
      alt: 'HCS Open Graph Image',
    }}
  >
    <Fragment slot="content">
      <p class="mb-4">
        Use this 1200×630 image for Open Graph tags, Twitter cards, and social media link previews. It's pre-sized for
        optimal display across platforms.
      </p>
    </Fragment>
  </Content>

  <!-- CTA **************** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Contact Us',
        href: '/contact',
        icon: 'tabler:mail',
      },
    ]}
  >
    <Fragment slot="title">Need Something Custom?</Fragment>
    <Fragment slot="subtitle">
      If you need a specific format, size, or co-branded version of our assets, reach out and we'll get it to you.
    </Fragment>
  </CallToAction>
</Layout>
